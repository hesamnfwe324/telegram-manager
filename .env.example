# =========================================
# Telegram User Client (Telethon)
# =========================================
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+989123456789
TELEGRAM_SESSION_NAME=tg_session
# REQUIRED for Docker/Render — generate with: python -m app.cli login
TELEGRAM_SESSION_STRING=

# =========================================
# Telegram Bot (Aiogram)
# =========================================
BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =========================================
# Admin Access (comma-separated user IDs)
# =========================================
ADMIN_IDS=123456789,987654321

# =========================================
# Database
# =========================================
DATABASE_URL=postgresql://tgmanager:secret@localhost:5432/tgmanager

# =========================================
# Redis (strongly recommended for production)
# Without this, FSM states are lost on restart
# =========================================
REDIS_URL=redis://localhost:6379/0

# =========================================
# Application
# =========================================
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# =========================================
# Discovery filters
# Leave empty to scan ALL messages
# =========================================
DISCOVERY_KEYWORDS=
MAX_JOINS_PER_DAY=50

# =========================================
# Join Queue (anti-detection jitter)
# =========================================
JOIN_DELAY_MIN=240
JOIN_DELAY_MAX=480

# =========================================
# Auto-retry for failed joins
# =========================================
RETRY_FAILED_JOINS=true
RETRY_INTERVAL_HOURS=6
RETRY_MAX_ATTEMPTS=3

# =========================================
# Backup
# =========================================
BACKUP_DIR=/tmp/backups
BACKUP_KEEP_DAYS=7
BACKUP_DAILY_HOUR=3

# =========================================
# S3/Cloudflare R2 Backup Upload (optional)
# =========================================
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# =========================================
# Docker Compose (local only)
# =========================================
POSTGRES_USER=tgmanager
POSTGRES_PASSWORD=secret
POSTGRES_DB=tgmanager
